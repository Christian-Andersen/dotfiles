set dotenv-load

alias a := audit
alias b := build
alias c := check
alias r := run
alias t := test
alias ci := continuous_integration

[private]
default:
    @just --choose

bootstrap:
    @command -v npm >/dev/null 2>&1 || { echo "Error: npm is required but was not found in PATH." >&2; exit 1; }
    @command -v prek >/dev/null 2>&1 || { echo "Error: prek is required but was not found in PATH." >&2; exit 1; }
    npm ci

audit:
    npm audit

check:
    prek run --all-files

build:
    npm run build

run:
    npm start

test:
    npm test

continuous_integration: bootstrap audit check build test
