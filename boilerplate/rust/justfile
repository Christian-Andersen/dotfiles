set dotenv-load

alias a := audit
alias b := build
alias c := check
alias d := doc
alias r := run
alias ci := continuous_integration

[private]
default:
    @just --choose

check:
    prek run --all-files

audit:
    cargo audit

build *args:
    cargo build --release {{ args }}

doc *args:
    cargo doc {{ args }}

run *args:
    cargo run {{ args }}

continuous_integration: audit check build doc
